# Authentication Environment Variables

# Auth.js / NextAuth.js Configuration
# Leave AUTH_URL/NEXTAUTH_URL unset for localhost, Vercel, and forwarded/global dev links.
# With AUTH_TRUST_HOST enabled, Auth.js uses the current request host.
AUTH_TRUST_HOST=true
AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Database Configuration (PostgreSQL)
# Supabase/Vercel integration provides these automatically.
DATABASE_POSTGRES_PRISMA_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true
DATABASE_POSTGRES_URL_NON_POOLING=postgresql://user:password@host:5432/postgres

# Gmail (used for OTP verification emails and new-course notifications)
# Set these to the lumen.berea@gmail.com account credentials.
GMAIL_USER=lumen.berea@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password-here
