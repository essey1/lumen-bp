# Authentication Environment Variables

# Auth.js / NextAuth.js Configuration
# Leave AUTH_URL/NEXTAUTH_URL unset for localhost, Vercel, and forwarded/global dev links.
# With AUTH_TRUST_HOST enabled, Auth.js uses the current request host.
AUTH_TRUST_HOST=true
AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Database Configuration (PostgreSQL)
# Example: postgresql://user:password@localhost:5432/lumen_bp
DATABASE_URL=postgresql://user:password@localhost:5432/database_name
